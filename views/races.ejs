<!DOCTYPE html>
<html>
<head>
  <title>Races</title>
</head>

<body>

<nav>
  <a href="/drivers">Fahrer</a>
  <a href="/races">Rennergebnisse</a>
</nav>

<h2>Race Eingabe</h2>

<form method="POST" action="/race/save">

<table border="1">

<tr>
  <th>Start</th>
  <th>Team</th>
  <th>Fahrer</th>
  <th>Platzierung</th>
</tr>

<% grid.forEach((g, i) => { %>
<tr>

  <td><%= g.start %></td>

  <td>
    <select name="team_<%= i %>" class="team">
      <option value="<%= g.team %>"><%= g.team %></option>
      <% db.teams.forEach(t => { %>
        <option><%= t.name %></option>
      <% }) %>
    </select>
  </td>

  <td>
    <select name="driver_<%= i %>" class="driver">
      <option value="<%= g.driver %>"><%= g.driver %></option>
    </select>
  </td>

  <td>
    <input name="pos_<%= i %>" type="number" min="1" max="22">
  </td>

</tr>
<% }) %>

</table>

<button>Speichern</button>

</form>

<script>
const db = <%- JSON.stringify(db) %>;

document.querySelectorAll(".team").forEach((teamSelect, index) => {
  teamSelect.addEventListener("change", function () {

    const driverSelect = document.querySelectorAll(".driver")[index];

    const team = db.teams.find(t => t.name === this.value);

    driverSelect.innerHTML = "";

    if (team) {
      team.drivers.forEach(d => {
        const opt = document.createElement("option");
        opt.value = d;
        opt.textContent = d;
        driverSelect.appendChild(opt);
      });
    }
  });
});
</script>

</body>
</html>
