<nav>
  <a href="/drivers">Fahrer</a> |
  <a href="/race">Rennen</a> |
  <a href="/grid">Grid</a>
</nav>

<hr>

<h1>Teams & Fahrer</h1>

<!-- TEAM HINZUFÜGEN -->
<form method="POST" action="/teams/add">
  <input name="name" placeholder="Teamname">
  <button>Team hinzufügen</button>
</form>

<hr>

<div style="display:flex; gap:20px;">

  <% teams.forEach(team => { %>
    <div style="border:1px solid #ccc; padding:10px; width:220px;">
      <h3><%= team.name %></h3>

      <!-- Fahrer Liste -->
      <% drivers.filter(d => d.team_id === team.id).forEach(d => { %>
        <div>
          <%= d.name %>

          <form method="POST" action="/drivers/delete" style="display:inline;">
            <input type="hidden" name="id" value="<%= d.id %>">
            <button>X</button>
          </form>
        </div>
      <% }) %>

      <!-- Fahrer hinzufügen -->
      <form method="POST" action="/drivers/add">
        <input name="name" placeholder="Fahrer">
        <input type="hidden" name="team_id" value="<%= team.id %>">
        <button>+</button>
      </form>

    </div>
  <% }) %>

</div>
