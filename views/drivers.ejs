<!DOCTYPE html>
<html>
<head>
  <title>Drivers</title>
</head>

<body>

<nav>
  <a href="/drivers">Fahrer</a>
  <a href="/races">Rennergebnisse</a>
</nav>

<h2>Team erstellen</h2>
<form method="POST" action="/team/add">
  <input name="team" placeholder="Team Name">
  <button>Hinzufügen</button>
</form>

<h2>Fahrer verwalten</h2>

<% db.teams.forEach(team => { %>
  <h3><%= team.name %></h3>

  <form method="POST" action="/driver/add">
    <input type="hidden" name="team" value="<%= team.name %>">
    <input name="driver" placeholder="Fahrer Name">
    <button>Hinzufügen</button>
  </form>

  <ul>
    <% team.drivers.forEach(driver => { %>
      <li>
        <%= driver %>
        <form method="POST" action="/driver/delete" style="display:inline">
          <input type="hidden" name="team" value="<%= team.name %>">
          <input type="hidden" name="driver" value="<%= driver %>">
          <button>❌</button>
        </form>
      </li>
    <% }) %>
  </ul>

<% }) %>

</body>
</html>
