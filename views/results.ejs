<h1>Rennergebnisse (28 Rennen)</h1>

<% races.forEach(race => { %>

<h2>Rennen <%= race.id %></h2>

<table>
  <thead>
    <tr>
      <th>Start</th>
      <th>Team</th>
      <th>Fahrer</th>
      <th>Platzierung</th>
    </tr>
  </thead>

  <tbody>
    <% race.results.forEach(r => { %>
      <tr>
        <td><%= r.start %></td>

        <td><input value="<%= r.team %>" 
          onchange="update(<%= race.id %>, <%= r.start %>, this.value, 'team')"></td>

        <td><input value="<%= r.driver %>"
          onchange="update(<%= race.id %>, <%= r.start %>, this.value, 'driver')"></td>

        <td><input type="number" min="1" max="22"
          onchange="update(<%= race.id %>, <%= r.start %>, this.value, 'position')"></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<button onclick="gen('<%= race.id %>')">Reverse Grid → nächstes Rennen</button>

<hr>

<% }) %>

<script>
function update(raceId, start, value, field) {
  fetch('/results/update', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({
      raceId,
      start,
      [field]: value
    })
  });
}

function gen(raceId) {
  fetch('/grid/generate/' + raceId, { method: 'POST' })
    .then(() => location.reload());
}
</script>