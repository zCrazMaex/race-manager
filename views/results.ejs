<h1>Rennergebnisse</h1>

<% races.forEach(race => { %>

<h2>Rennen <%= race.id %></h2>

<table>
  <thead>
    <tr>
      <th>Start</th>
      <th>Team</th>
      <th>Fahrer</th>
      <th>Platzierung</th>
    </tr>
  </thead>

  <tbody>
    <% race.results.forEach(r => { %>
      <tr>
        <td><%= r.start %></td>

        <!-- TEAM DROPDOWN -->
        <td>
          <select onchange="setTeam(<%= race.id %>, <%= r.start %>, this)">
            <option value="">Team wählen</option>

            <% teams.forEach(t => { %>
              <option value="<%= t.name %>" <%= r.team === t.name ? "selected" : "" %>>
                <%= t.name %>
              </option>
            <% }) %>

          </select>
        </td>

        <!-- DRIVER DROPDOWN (abhängig vom Team) -->
        <td>
          <select id="driver-<%= race.id %>-<%= r.start %>"
                  onchange="setDriver(<%= race.id %>, <%= r.start %>, this)"
                  <%= !r.team ? "disabled" : "" %>>

            <option value="">Fahrer wählen</option>

            <% 
              let selectedTeam = teams.find(t => t.name === r.team);
              let drivers = selectedTeam ? selectedTeam.drivers : [];
            %>

            <% drivers.forEach(d => { %>
              <option value="<%= d %>" <%= r.driver === d ? "selected" : "" %>>
                <%= d %>
              </option>
            <% }) %>

          </select>
        </td>

        <!-- POSITION -->
        <td>
          <input type="number" min="1" max="22"
            value="<%= r.position || '' %>"
            onchange="updatePosition(<%= race.id %>, <%= r.start %>, this.value)">
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<button onclick="gen(<%= race.id %>)">
  Reverse Grid erstellen
</button>

<hr>

<% }) %>

<script>
function setTeam(raceId, start, el) {
  const team = el.value;

  fetch('/results/update', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ raceId, start, team })
  });
}

function setDriver(raceId, start, el) {
  const driver = el.value;

  fetch('/results/update', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ raceId, start, driver })
  });
}

function updatePosition(raceId, start, position) {
  fetch('/results/update', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ raceId, start, position })
  });
}

function gen(raceId) {
  fetch('/grid/generate/' + raceId, { method: 'POST' });
}
</script>
